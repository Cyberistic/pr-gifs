#!/bin/bash

# makegif - Convert video files to optimized GIFs
# Usage: makegif file1.mp4 file2.mov ...
# Output: Creates dated GIF files (e.g., output_2025-03-05_14-30-22.gif)

set -e

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Check if ffmpeg is installed
if ! command -v ffmpeg &> /dev/null; then
    echo -e "${RED}Error: ffmpeg is not installed${NC}"
    echo "Please install ffmpeg first:"
    echo "  macOS: brew install ffmpeg"
    echo "  Ubuntu/Debian: sudo apt-get install ffmpeg"
    echo "  Windows: choco install ffmpeg"
    exit 1
fi

# Check if any files were provided
if [ $# -eq 0 ]; then
    echo -e "${YELLOW}Usage: makegif <video_file1> [video_file2] [video_file3] ...${NC}"
    echo ""
    echo "Converts video files to optimized GIFs under 5MB"
    echo "Output files will be dated: output_YYYY-MM-DD_HH-MM-SS.gif"
    exit 1
fi

# Counter for successful conversions
success_count=0
failed_count=0

# Array to track created files
  declare -a created_files

  # Process each file
  for input_file in "$@"; do
      # Check if file exists
      if [ ! -f "$input_file" ]; then
          echo -e "${RED}✗ File not found: $input_file${NC}"
          ((failed_count++))
          continue
      fi

      # Get file info
      filename=$(basename "$input_file")
      extension="${filename##*.}"
      basename="${filename%.*}"
      input_dir=$(dirname "$input_file")

      # Generate dated output filename in the same directory as input
      timestamp=$(date +"%Y-%m-%d_%H-%M-%S")
      output_file="${input_dir}/${basename}_${timestamp}.gif"
    
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BLUE}Converting:${NC} $filename"
    echo -e "${BLUE}Output:${NC}    $output_file"
    echo ""
    
    # Get input file size
    input_size=$(du -h "$input_file" | cut -f1)
    echo -e "${YELLOW}Input size:${NC} $input_size"
    
    # Convert to GIF with optimized settings
    # Settings optimized for screen recordings with text
    if ffmpeg -i "$input_file" \
        -vf "fps=8,scale=600:-1:flags=lanczos,split[s0][s1];[s0]palettegen=max_colors=20[p];[s1][p]paletteuse=dither=bayer" \
        -loop 0 \
        -hide_banner \
        -loglevel warning \
        -stats \
        "$output_file" 2>&1; then
        
        # Get output file size
        output_size=$(du -h "$output_file" | cut -f1)

        echo ""
        echo -e "${GREEN}✓ Success!${NC}"
        echo -e "${GREEN}Output size:${NC} $output_size"
        echo ""
        created_files+=("$output_file")
        ((success_count++))
    else
        echo -e "${RED}✗ Failed to convert: $filename${NC}"
        ((failed_count++))
    fi
done

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
echo -e "${GREEN}Conversion complete!${NC}"
echo -e "  ${GREEN}Successful:${NC} $success_count"
echo -e "  ${RED}Failed:${NC}     $failed_count"
echo ""

if [ $success_count -gt 0 ]; then
    echo -e "${GREEN}Created files:${NC}"
    for file in "${created_files[@]}"; do
        if [ -f "$file" ]; then
            size=$(du -h "$file" | cut -f1)
            echo "  $file ($size)"
        fi
    done
    echo ""
fi

exit 0
